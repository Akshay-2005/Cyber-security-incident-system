# =========================================================================
# AEGIS SENTINEL: SYSTEM CONFIGURATION BLUEPRINT
# =========================================================================

# --- BACKEND SERVER CONFIGURATION ---
PORT=5001
NODE_ENV=development

# --- DATABASE CONFIGURATION ---
# MongoDB Atlas Connection String or Local MongoDB URI
# Format: mongodb://localhost:27017/aegissentinel or mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/aegissentinel

# --- AUTHENTICATION CONFIGURATION ---
# Cryptographically strong secret key for JWT session encryption
JWT_SECRET=super_secret_neon_cyber_security_sentinel_token_key_2026
JWT_EXPIRES_IN=24h

# --- AUTOMATIC ALERTS / EMAIL SERVICE (NODEMAILER) ---
# Supports Ethereal SMTP test credentials or corporate mail relays (e.g., SendGrid, Mailgun)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=585
SMTP_USER=test.analyst.alerts@ethereal.email
SMTP_PASS=mock_smtp_password_here
EMAIL_FROM="AegisSentinel Alerts <alerts@aegissentinel.gov>"

# --- SALESFORCE REST API INTEGRATION ---
# Integration mode: 'REAL' (performs direct OAuth 2.0 and REST calls) or 'SIMULATED' (mocks transactions with rich log reports)
SF_INTEGRATION_MODE=SIMULATED

# Salesforce Org Credentials
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=3MVG9t0bPH4.8S_xxxxxxxxxxxxxxxxxxxxxxxxxx
SF_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SF_USERNAME=admin@aegissentinel.com
SF_PASSWORD=superSecretSFPassword123
SF_SECURITY_TOKEN=abcdefghijklmnopqrstuvwxyz12345
